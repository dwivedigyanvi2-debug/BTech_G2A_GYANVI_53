#include<stdio.h>
int main(){
    float pi = 3.14;
    float area , circumference;
    float radius;
    
    printf("Enter the radius of the circle - ");
    scanf("%f",&radius);
    
    area = pi*radius*radius;
    circumference = 2*pi*radius;
    
    printf("\nThe area and circumference of the circle is %.2f and %.2f",area,circumference);
    
    
    return 0;
}
