#include<stdio.h>
int main(){
    
    int a , b ,c =0;
    printf("Enter two numbers - ");
    scanf("%d\t%d",&a,&b);
    printf("\nThe value before swapping is %d and %d",a,b);
    
    c = a;
    a = b ;
    b = c ;
    printf("\nThe value after swapping is %d and %d",a,b);
    
    
    
    return 0;
}
